{{!-- The sheet's root element is already a <form> (DocumentSheetV2), so this
      wrapper must not be one: a nested form would capture the inputs and
      break submitOnChange. --}}
<div class="nco-character-sheet {{#if editing}}nco-editing{{/if}}">
  <header class="nco-sheet-header">
    {{#if editable}}
      <img class="nco-portrait nco-portrait-editable" src="{{actor.img}}" alt="{{actor.name}}"
           data-action="editImage" title="{{localize 'NCO.Sheet.EditImage'}}" />
    {{else}}
      <img class="nco-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
    {{/if}}
    <div class="nco-header-fields">
      {{#if editing}}
        <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'NCO.Sheet.NamePlaceholder'}}" />
      {{else}}
        <h1 class="nco-name">{{actor.name}}</h1>
      {{/if}}
      <div class="nco-hits">
        <span class="nco-section-label nco-danger-label nco-hits-label">{{localize "NCO.Sheet.Hits"}}</span>
        {{#each hitBoxes as |box|}}
          <input type="checkbox" class="nco-hit-box" data-action="toggleHit" data-index="{{box.index}}"
                 {{checked box.checked}} {{#unless @root.editable}}disabled{{/unless}}
                 title="{{localize 'NCO.Sheet.HitBox'}}" />
        {{/each}}
        {{#if editing}}
          <input type="number" class="nco-hits-max" name="system.hits.max" value="{{system.hits.max}}"
                 min="1" max="{{hitsMaxLimit}}" step="1" title="{{localize 'NCO.Sheet.HitsMax'}}" />
        {{/if}}
      </div>
      <div class="nco-stunt-points">
        {{#if editable}}
          <button type="button" class="nco-stunt-label" data-action="spendStuntPoint"
                  title="{{localize 'NCO.Sheet.SpendStuntPoint'}}">
            {{localize "NCO.Sheet.StuntPoints"}}
          </button>
        {{else}}
          <span class="nco-section-label nco-stunt-static">{{localize "NCO.Sheet.StuntPoints"}}</span>
        {{/if}}
        <input type="number" class="nco-stunt-input" name="system.stuntPoints"
               value="{{system.stuntPoints}}" min="0" step="1"
               {{#unless editable}}disabled{{/unless}} />
      </div>
    </div>
    {{#if editable}}
      <button type="button" class="nco-icon-button nco-edit-toggle {{#if editing}}nco-edit-toggle-active{{/if}}"
              data-action="toggleEdit" title="{{localize 'NCO.Sheet.ToggleEdit'}}"
              aria-label="{{localize 'NCO.Sheet.ToggleEdit'}}">
        <i class="fas {{#if editing}}fa-unlock{{else}}fa-lock{{/if}}"></i>
      </button>
    {{/if}}
  </header>

  <section class="nco-description">
    <label class="nco-section-label">{{localize "NCO.Sheet.Description"}}</label>
    {{#if editing}}
      <textarea name="system.description" rows="4">{{system.description}}</textarea>
    {{else}}
      <div class="nco-description-text">{{{descriptionHTML}}}</div>
    {{/if}}
  </section>

  <section class="nco-trademarks">
    <div class="nco-section-header">
      <label class="nco-section-label">{{localize "NCO.Sheet.Trademarks"}}</label>
      {{#if editing}}
        <button type="button" class="nco-add" data-action="createTrademark">
          <i class="fas fa-plus"></i> {{localize "NCO.Sheet.AddTrademark"}}
        </button>
      {{/if}}
    </div>

    {{#if editing}}
      {{#each trademarks as |trademark trademarkIndex|}}
        <div class="nco-trademark">
          <div class="nco-trademark-header">
            <input type="text" class="nco-trademark-name"
                   name="system.trademarks.{{trademarkIndex}}.name"
                   value="{{trademark.name}}" placeholder="{{localize 'NCO.Sheet.TrademarkPlaceholder'}}" />
            <button type="button" class="nco-icon-button nco-delete" data-action="deleteTrademark"
                    data-trademark-index="{{trademarkIndex}}"
                    title="{{localize 'NCO.Sheet.DeleteTrademark'}}" aria-label="{{localize 'NCO.Sheet.DeleteTrademark'}}">
              <i class="fas fa-trash"></i>
            </button>
          </div>

          <ul class="nco-tags">
            {{#each trademark.triggers as |trigger triggerIndex|}}
              <li class="nco-trigger {{#if trigger.edge}}nco-trigger-edge{{/if}}">
                {{!-- Block params (trademarkIndex) are lexically scoped and must be
                      referenced directly: a ../ prefix bypasses block params and
                      resolves to undefined, silently corrupting the input names. --}}
                <label class="nco-edge-toggle" title="{{localize 'NCO.Sheet.MarkEdge'}}">
                  <input type="checkbox"
                         name="system.trademarks.{{trademarkIndex}}.triggers.{{triggerIndex}}.edge"
                         {{checked trigger.edge}} />
                  <i class="fas fa-bolt"></i>
                </label>
                <input type="text" class="nco-trigger-text"
                       name="system.trademarks.{{trademarkIndex}}.triggers.{{triggerIndex}}.text"
                       value="{{trigger.text}}" placeholder="{{localize 'NCO.Sheet.TriggerPlaceholder'}}" />
                <button type="button" class="nco-icon-button nco-delete" data-action="deleteTrigger"
                        data-trademark-index="{{trademarkIndex}}" data-trigger-index="{{triggerIndex}}"
                        title="{{localize 'NCO.Sheet.DeleteTrigger'}}" aria-label="{{localize 'NCO.Sheet.DeleteTrigger'}}">
                  <i class="fas fa-times"></i>
                </button>
              </li>
            {{/each}}
          </ul>

          <button type="button" class="nco-add nco-add-trigger" data-action="createTrigger"
                  data-trademark-index="{{trademarkIndex}}">
            <i class="fas fa-plus"></i> {{localize "NCO.Sheet.AddTrigger"}}
          </button>
        </div>
      {{else}}
        <p class="nco-empty-hint">{{localize "NCO.Sheet.EmptyTrademarks"}}</p>
      {{/each}}
    {{else}}
      {{#each trademarks as |trademark|}}
        <div class="nco-trademark">
          <div class="nco-trademark-header">
            {{#if trademark.clickable}}
              <button type="button" class="nco-chip nco-chip-trademark"
                      data-action="invoke" data-text="{{trademark.name}}" data-polarity="positive"
                      title="{{@root.invokePositiveTitle}}">
                {{trademark.name}}
              </button>
            {{else}}
              <span class="nco-chip nco-chip-trademark nco-chip-static">—</span>
            {{/if}}
          </div>
          <ul class="nco-tags nco-tags-play">
            {{#each trademark.triggers as |trigger|}}
              <li>
                {{#if trigger.clickable}}
                  <button type="button" class="nco-chip nco-chip-tag nco-chip-edge"
                          data-action="invoke" data-text="{{trigger.text}}" data-polarity="positive"
                          title="{{@root.invokePositiveTitle}}">
                    <i class="fas fa-bolt"></i> {{trigger.text}}
                  </button>
                {{else}}
                  <span class="nco-chip nco-chip-tag nco-chip-static">{{trigger.text}}</span>
                {{/if}}
              </li>
            {{/each}}
          </ul>
        </div>
      {{else}}
        <p class="nco-empty-hint">{{localize "NCO.Sheet.EmptyTrademarks"}}</p>
      {{/each}}
    {{/if}}
  </section>

  <section class="nco-flaws">
    <label class="nco-section-label nco-danger-label">{{localize "NCO.Sheet.Flaws"}}</label>
    {{#if editing}}
      <div class="nco-flaw-inputs">
        {{#each flaws as |flaw flawIndex|}}
          <input type="text" class="nco-flaw-text" name="system.flaws.{{flawIndex}}"
                 value="{{flaw.text}}" placeholder="{{localize 'NCO.Sheet.FlawPlaceholder'}}" />
        {{/each}}
      </div>
    {{else}}
      <ul class="nco-tags nco-tags-play">
        {{#each flaws as |flaw|}}
          <li>
            {{#if flaw.clickable}}
              <button type="button" class="nco-chip nco-chip-flaw"
                      data-action="invoke" data-polarity="negative" data-text="{{flaw.text}}"
                      title="{{@root.invokeNegativeTitle}}">
                <i class="fas fa-skull"></i> {{flaw.text}}
              </button>
            {{else}}
              <span class="nco-chip nco-chip-flaw nco-chip-static">—</span>
            {{/if}}
          </li>
        {{/each}}
      </ul>
    {{/if}}
  </section>

  <section class="nco-traumas">
    <div class="nco-section-header">
      <label class="nco-section-label nco-danger-label">{{localize "NCO.Sheet.Traumas"}}</label>
      {{#if editable}}
        <button type="button" class="nco-add" data-action="createTrauma">
          <i class="fas fa-plus"></i> {{localize "NCO.Sheet.AddTrauma"}}
        </button>
      {{/if}}
    </div>
    {{#if editing}}
      {{#each traumas as |trauma traumaIndex|}}
        <div class="nco-trauma-row">
          <input type="text" class="nco-flaw-text" name="system.traumas.{{traumaIndex}}"
                 value="{{trauma.text}}" placeholder="{{localize 'NCO.Sheet.TraumaNamePlaceholder'}}" />
          <button type="button" class="nco-icon-button nco-delete" data-action="deleteTrauma"
                  data-trauma-index="{{traumaIndex}}"
                  title="{{localize 'NCO.Sheet.DeleteTrauma'}}" aria-label="{{localize 'NCO.Sheet.DeleteTrauma'}}">
            <i class="fas fa-times"></i>
          </button>
        </div>
      {{/each}}
    {{else}}
      <ul class="nco-tags nco-tags-play">
        {{#each traumas as |trauma|}}
          <li>
            {{#if trauma.clickable}}
              <button type="button" class="nco-chip nco-chip-flaw" data-action="invoke"
                      data-polarity="negative" data-text="{{trauma.text}}"
                      title="{{@root.invokeNegativeTitle}}">
                <i class="fas fa-heart-broken"></i> {{trauma.text}}
              </button>
            {{else}}
              <span class="nco-chip nco-chip-static">{{trauma.text}}</span>
            {{/if}}
          </li>
        {{/each}}
      </ul>
    {{/if}}
  </section>

  <section class="nco-conditions">
    <div class="nco-section-header">
      <label class="nco-section-label nco-danger-label">{{localize "NCO.Sheet.Conditions"}}</label>
      {{#if editable}}
        <button type="button" class="nco-add" data-action="createCondition">
          <i class="fas fa-plus"></i> {{localize "NCO.Sheet.AddCondition"}}
        </button>
      {{/if}}
    </div>
    <ul class="nco-conditions-list">
      {{#each conditions as |condition|}}
        <li class="nco-condition">
          <label class="nco-edge-toggle nco-condition-toggle" title="{{localize 'NCO.Sheet.ToggleCondition'}}">
            <input type="checkbox" data-action="toggleCondition" data-item-id="{{condition.id}}"
                   {{checked condition.active}} {{#unless @root.editable}}disabled{{/unless}} />
            <i class="fas fa-exclamation-triangle"></i>
          </label>
          {{#if condition.active}}
            <button type="button" class="nco-chip nco-chip-flaw" data-action="invoke"
                    data-polarity="negative" data-text="{{condition.name}}"
                    title="{{@root.invokeNegativeTitle}}">
              {{condition.name}}
            </button>
          {{else}}
            <span class="nco-chip nco-chip-static">{{condition.name}}</span>
          {{/if}}
          {{#if @root.editing}}
            <button type="button" class="nco-icon-button nco-delete" data-action="deleteCondition"
                    data-item-id="{{condition.id}}"
                    title="{{localize 'NCO.Sheet.DeleteCondition'}}" aria-label="{{localize 'NCO.Sheet.DeleteCondition'}}">
              <i class="fas fa-times"></i>
            </button>
          {{/if}}
        </li>
      {{/each}}
    </ul>
  </section>
</div>
