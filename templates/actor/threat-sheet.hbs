{{!-- The sheet's root element is already a <form> (DocumentSheetV2), so this
      wrapper must not be one: a nested form would capture the inputs and
      break submitOnChange. --}}
<div class="nco-threat-sheet {{#if editing}}nco-editing{{/if}}">
  <header class="nco-sheet-header">
    {{#if editable}}
      <img class="nco-portrait nco-portrait-editable" src="{{actor.img}}" alt="{{actor.name}}"
           data-action="editImage" title="{{localize 'NCO.Sheet.EditImage'}}" />
    {{else}}
      <img class="nco-portrait" src="{{actor.img}}" alt="{{actor.name}}" />
    {{/if}}
    <div class="nco-header-fields">
      {{!-- Danger Rating: a special negative Tag shown as a red circle. Clicking
            it adds its rating's worth of Danger dice to the shared roll pool. --}}
      <div class="nco-threat-namerow">
        {{#if editing}}
          <input type="number" class="nco-danger-rating nco-danger-rating-input"
                 name="system.dangerRating" value="{{system.dangerRating}}" min="0" step="1"
                 title="{{localize 'NCO.Sheet.DangerRating'}}" />
        {{else}}
          <button type="button" class="nco-danger-rating" data-action="invokeDanger"
                  title="{{invokeDangerTitle}}">{{dangerRating}}</button>
        {{/if}}
        {{#if editing}}
          <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'NCO.Sheet.NamePlaceholder'}}" />
        {{else}}
          <h1 class="nco-name">{{actor.name}}</h1>
        {{/if}}
      </div>

      {{!-- Boss toggle: triples the Threat's Hits. Available whenever the user
            can edit the actor, since it changes how much punishment it takes. --}}
      <label class="nco-boss-toggle" title="{{localize 'NCO.Sheet.BossHint'}}">
        <input type="checkbox" name="system.boss" {{checked system.boss}}
               {{#unless editable}}disabled{{/unless}} />
        <span>{{localize "NCO.Sheet.Boss"}}</span>
      </label>

      <div class="nco-hits">
        <span class="nco-section-label nco-danger-label nco-hits-label">{{localize "NCO.Sheet.Hits"}}</span>
        {{!-- Click behavior (add/remove vs fill-to-level) is set in JS by the
              world's track-click-mode setting, shared with the character sheet. --}}
        <div class="nco-hits-track nco-track" data-action="trackAdd" title="{{trackHint}}">
          {{#each hitGroups as |group|}}
            {{#unless @first}}<hr class="nco-hit-divider" />{{/unless}}
            <div class="nco-hit-group">
              {{#each group as |box|}}
                <span class="nco-hit-box {{#if box.checked}}nco-hit-box-filled{{/if}}"
                      data-index="{{box.index}}"></span>
              {{/each}}
            </div>
          {{/each}}
        </div>
        {{#if editing}}
          <input type="number" class="nco-hits-max" name="system.hits.max" value="{{system.hits.max}}"
                 min="1" step="1" title="{{localize 'NCO.Sheet.HitsMax'}}" />
        {{/if}}
      </div>
    </div>
    {{#if editable}}
      <button type="button" class="nco-icon-button nco-edit-toggle {{#if editing}}nco-edit-toggle-active{{/if}}"
              data-action="toggleEdit" title="{{localize 'NCO.Sheet.ToggleEdit'}}"
              aria-label="{{localize 'NCO.Sheet.ToggleEdit'}}">
        <i class="fas {{#if editing}}fa-unlock{{else}}fa-lock{{/if}}"></i>
      </button>
    {{/if}}
  </header>

  <section class="nco-drive">
    <label class="nco-section-label">{{localize "NCO.Sheet.Drive"}}</label>
    {{#if editing}}
      <textarea name="system.drive" rows="2" placeholder="{{localize 'NCO.Sheet.ThreatDrivePlaceholder'}}">{{system.drive}}</textarea>
    {{else}}
      <div class="nco-description-text">{{{driveHTML}}}</div>
    {{/if}}
  </section>

  <section class="nco-threat-tags">
    <div class="nco-section-header">
      <label class="nco-section-label">{{localize "NCO.Sheet.Tags"}}</label>
      {{#if editing}}
        <button type="button" class="nco-add" data-action="createTag">
          <i class="fas fa-plus"></i> {{localize "NCO.Sheet.AddTag"}}
        </button>
      {{/if}}
    </div>

    {{#if editing}}
      <ul class="nco-tags">
        {{#each tags as |tag tagIndex|}}
          <li class="nco-gear-tag">
            <button type="button"
                    class="nco-polarity-toggle {{#if tag.positive}}nco-polarity-positive{{else}}nco-polarity-negative{{/if}}"
                    data-action="toggleTagPolarity" data-tag-index="{{tagIndex}}"
                    title="{{localize 'NCO.Sheet.ToggleTagPolarity'}}">
              <i class="fas {{#if tag.positive}}fa-plus{{else}}fa-minus{{/if}}"></i>
            </button>
            {{!-- Keep polarity in the form so a text-edit submit doesn't reset it
                  to the schema default. --}}
            <input type="hidden" name="system.tags.{{tagIndex}}.polarity" value="{{tag.polarity}}" />
            <input type="text" class="nco-trigger-text" name="system.tags.{{tagIndex}}.text"
                   value="{{tag.text}}" placeholder="{{localize 'NCO.Sheet.TagPlaceholder'}}" />
            <button type="button" class="nco-icon-button nco-delete" data-action="deleteTag"
                    data-tag-index="{{tagIndex}}"
                    title="{{localize 'NCO.Sheet.DeleteTag'}}" aria-label="{{localize 'NCO.Sheet.DeleteTag'}}">
              <i class="fas fa-times"></i>
            </button>
          </li>
        {{else}}
          <p class="nco-empty-hint">{{localize "NCO.Sheet.EmptyThreatTags"}}</p>
        {{/each}}
      </ul>
    {{else}}
      <ul class="nco-tags nco-tags-play">
        {{#each tags as |tag|}}
          <li>
            {{#if tag.clickable}}
              <button type="button"
                      class="nco-chip nco-chip-tag {{#if tag.positive}}nco-chip-edge{{else}}nco-chip-flaw{{/if}}"
                      data-action="invoke" data-text="{{tag.text}}"
                      data-polarity="{{#if tag.positive}}positive{{else}}negative{{/if}}"
                      title="{{#if tag.positive}}{{@root.invokePositiveTitle}}{{else}}{{@root.invokeNegativeTitle}}{{/if}}">
                <i class="fas {{#if tag.positive}}fa-plus{{else}}fa-minus{{/if}}"></i> {{tag.text}}
              </button>
            {{else}}
              <span class="nco-chip nco-chip-tag nco-chip-static">{{tag.text}}</span>
            {{/if}}
          </li>
        {{else}}
          <p class="nco-empty-hint">{{localize "NCO.Sheet.EmptyThreatTags"}}</p>
        {{/each}}
      </ul>
    {{/if}}
  </section>

  <section class="nco-threat-actions">
    <label class="nco-section-label">{{localize "NCO.Sheet.Actions"}}</label>
    {{#if editing}}
      <textarea name="system.actions" rows="4" placeholder="{{localize 'NCO.Sheet.ActionsPlaceholder'}}">{{system.actions}}</textarea>
    {{else}}
      <div class="nco-description-text">{{{actionsHTML}}}</div>
    {{/if}}
  </section>
</div>
